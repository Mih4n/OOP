<Window x:Class="Second.Wpf.First.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Assembly Stages" Height="600" Width="1000">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ================================== -->
        <!-- LEFT PANEL: Filters and Actions -->
        <!-- ================================== -->
        <StackPanel Grid.Column="0" Margin="5">

            <TextBlock Text="Filters and Actions"
                       FontWeight="Bold"
                       FontSize="16"
                       Margin="0 0 0 10"/>

            <!-- Filter by duration -->
            <CheckBox x:Name="UseDurationFilter"
                      Content="Duration >= "
                      IsChecked="True"/>
            <TextBox x:Name="DurationBox"
                     Text="30"
                     Margin="0 0 0 10"/>

            <!-- Filter by workshop -->
            <CheckBox x:Name="UseWorkshopFilter"
                      Content="Workshop Filter"
                      IsChecked="False"/>
            <TextBox x:Name="WorkshopBox"
                     Text="Workshop1"
                     Margin="0 0 0 10"/>

            <Separator Margin="0 10"/>

            <!-- Buttons -->
            <Button Content="Apply Filters"
                    Height="30"
                    Margin="0 5"
                    Click="Apply_Click"/>
            <Button Content="Reset Filters"
                    Height="30"
                    Margin="0 5"
                    Click="Reset_Click"/>

            <Separator Margin="0 10"/>

            <!-- Average time -->
            <Button Content="Calculate Average"
                    Height="30"
                    Margin="0 5"
                    Click="Average_Click"/>
            <TextBlock x:Name="AverageResult"
                       FontWeight="Bold"
                       Margin="0 5"/>

            <Separator Margin="0 10"/>

            <!-- Group by Danger -->
            <Button Content="Group by Danger"
                    Height="30"
                    Margin="0 5"
                    Click="Group_Click"/>
            <TextBlock Text="Grouped by Danger:"
                       FontWeight="Bold"
                       Margin="0 5"/>
            <ListBox x:Name="GroupResult"
                     Height="120"/>
        </StackPanel>

        <!-- ================================== -->
        <!-- MIDDLE PANEL: Source Data -->
        <!-- ================================== -->
        <StackPanel Grid.Column="1" Margin="5">
            <TextBlock Text="Source Data (JSON)"
                       FontWeight="Bold"
                       FontSize="16"
                       Margin="0 0 0 10"/>
            <ListBox x:Name="SourceList"/>
        </StackPanel>

        <!-- ================================== -->
        <!-- RIGHT PANEL: Filtered / Result Data -->
        <!-- ================================== -->
        <StackPanel Grid.Column="2" Margin="5">
            <TextBlock Text="Filtered / Result Data"
                       FontWeight="Bold"
                       FontSize="16"
                       Margin="0 0 0 10"/>
            <ListBox x:Name="ResultList"/>
        </StackPanel>
    </Grid>
</Window>
